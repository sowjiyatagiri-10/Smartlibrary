# =============================
# Git Ignore - Sensitive Files
# =============================

# Environment variables
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database files
*.db
*.db-wal
*.db-shm
backend/*.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build outputs
dist/
build/
.next/
out/

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
