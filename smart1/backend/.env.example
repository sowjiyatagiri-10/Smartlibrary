# =============================
# BACKEND ENVIRONMENT VARIABLES EXAMPLE
# Copy this to .env and fill in your values
# =============================

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
# For local development:
FRONTEND_URL=http://localhost:5173
# For production:
# FRONTEND_URL=https://your-frontend-domain.com

# Session Configuration
SESSION_SECRET=change_this_to_a_random_string_in_production

# Database Configuration
# Currently using SQLite - stored in backend/smart_library.db
# For MongoDB in future:
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/srkr_library

# Email Configuration (for reminders)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# Logging
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true
